---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogPost from "../layouts/BlogPost.astro";

const allPosts = Object.values(import.meta.glob('./posts/*.md', {eager: true}));
const pageTitle = "Blog";
---

<BaseLayout pageTitle={pageTitle}>
  <h2>Post 1:</h2>
  <p>Deskripsi Astro example blog</p>
  <ul>
    {allPosts.map((post: any) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
  </ul>
  <p>Deskripsi riwayat pembuatan game atau devlog game KopiMoca</p>
  <p>Deskripsi riwayat pembuatan game atau devlog game HalfMoon Duel</p>
</BaseLayout>